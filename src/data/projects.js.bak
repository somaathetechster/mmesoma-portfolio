      {
        label: "Daily business digest — AI summarising a trader's day in plain language",
        lang: "javascript",
        code: `// Every morning, each trader receives an AI-generated summary
// of their previous day — no dashboards, no spreadsheets
async function generateDailyDigest(traderId, date) {
  const [sales, inventory, credit] = await Promise.all([
    getSalesSummary(traderId, date),
    getInventoryAlerts(traderId),
    getCreditSummary(traderId),
  ]);

  const prompt = \`You are a friendly business advisor for a small trader in Nigeria.
    Summarise their business day in 4-5 short sentences.
    Be specific about numbers. Be encouraging but honest.
    Highlight the most important thing they should act on today.
    Write in simple English. Avoid jargon.
    
    Data: \${JSON.stringify({ sales, inventory, credit })}\`;

  const digest = await ai.generate({ user: prompt, maxTokens: 200 });

  // Deliver via WhatsApp — the trader's primary interface
  await sendWhatsAppMessage(trader.phone, digest);
  return { digest, delivered: true };
}`,
      },
      {
        label: "Credit risk scoring — using payment history to inform lending decisions",
        lang: "javascript",
        code: `// AI model scores a customer's creditworthiness
// based purely on their transaction history with the trader
async function scoreCustomerCredit(customerId, traderId) {
  const history = await getCustomerHistory(customerId, traderId);

  const features = {
    totalTransactions:    history.length,
    avgDaysToPay:         calculateAvgPaymentDelay(history),
    latePaymentRate:      history.filter(t => t.paidLate).length / history.length,
    largestCreditTaken:   Math.max(...history.map(t => t.creditAmount)),
    currentOutstanding:   history.filter(t => !t.settled).reduce((s, t) => s + t.amount, 0),
  };

  const { score, reasoning } = await ai.score({
    system: 'Credit scoring for informal trade. Score 0-100. Explain in one sentence.',
    user: JSON.stringify(features)
  });

  return {
    score,                    // 0-100
    recommendation: score > 65 ? 'EXTEND_CREDIT' : 'REQUEST_PARTIAL_UPFRONT',
    explanation: reasoning,   // plain language, shown to trader
  };
}`,
      }
