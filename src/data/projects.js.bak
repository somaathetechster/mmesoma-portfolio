    snippets: [
      {
        label: "Goal-to-recommendation engine — translating user intent into staking options",
        lang: "javascript",
        code: `// User tells us what they want in plain terms
// AI maps that to concrete staking recommendations
async function recommendStakingOptions(userProfile) {
  const { riskTolerance, targetReturn, lockupPreference } = userProfile;

  const systemPrompt = \`You are a staking advisor. Given a user's financial goals,
    recommend 2-3 staking options from the available pools below.
    Explain each option in plain language. Never use jargon without explaining it.
    Risk tolerance: \${riskTolerance} | Target APY: \${targetReturn}%\`;

  const availablePools = await fetchActivePools();

  const recommendations = await ai.complete({
    system: systemPrompt,
    user: \`Available pools: \${JSON.stringify(availablePools)}
           User preference on lock-up: \${lockupPreference}\`,
    format: 'structured_recommendations'
  });

  return enrichWithLiveData(recommendations);
}`
      }
    ],
    lessons: "AI is most valuable in financial products when it reduces cognitive load without reducing user agency. The goal is informed decisions made faster — not decisions made for you.",
