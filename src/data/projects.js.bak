    ],
    snippets: [
      {
        label: "NLP intent routing — what happens when a user sends a message",
        lang: "javascript",
        code: `// Every incoming message passes through the AI classification layer
// before touching any business logic
async function classifyAndRoute(session, rawMessage) {
  const { intent, entities, confidence } = await nlpClassify(rawMessage);

  // Low confidence → ask the user to clarify rather than guess
  if (confidence < 0.72) {
    return generateClarificationPrompt(rawMessage, session.context);
  }

  // Map detected intent to the correct financial workflow
  const handlers = {
    SEND_FIAT:       () => initiateFiatTransfer(session, entities),
    BUY_CRYPTO:      () => initiateCryptoPurchase(session, entities),
    SELL_CRYPTO:     () => initiateCryptoSale(session, entities),
    CHECK_BALANCE:   () => fetchAndFormatBalance(session),
    BUY_AIRTIME:     () => initiateAirtimePurchase(session, entities),
    START_KYC:       () => beginKYCFlow(session),
  };

  return handlers[intent]?.() ?? handleUnknownIntent(session, rawMessage);
}`
      },
      {
        label: "Entity extraction — parsing 'send 50k to Amaka GTB' into structured data",
        lang: "javascript",
        code: `// AI extracts structured financial data from conversational input
// "send 50k to my sister Amaka, her GTB number is 0123456789"
async function extractTransferEntities(message) {
  const prompt = buildEntityExtractionPrompt(message, {
    targets: ['amount', 'currency', 'recipient_name', 'bank_name', 'account_number'],
    context: 'Nigerian financial transaction',
    normalisations: {
      '50k': 50000, '5k': 5000,   // local shorthand
      'GTB': 'Guaranty Trust Bank',
      'UBA': 'United Bank for Africa',
    }
  });

  const extracted = await aiClient.extract(prompt);

  // Validate before any transaction logic runs
  return validateTransferEntities(extracted);
}`
      }
    ],
    lessons: "The most important AI design principle I learned here: a system that admits uncertainty is more trustworthy than one that guesses confidently. The confidence threshold and clarification flow made users trust the system more, not less.",
